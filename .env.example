SIGNNOW_API_KEY=
SIGNNOW_API_BASE=https://api.signnow.com

# Optional local active human operator for RB Codex runs.
# Valid names are recorded in internal/people-roles.md.
# This must be a human name, not a shared mailbox such as accounting@richmondblackwood.com.
RB_CODEX_ACTOR="Ioana Surdu-Bob"

# Optional shared Google helper auth overrides.
# Durable Google persona credentials and OAuth client files belong under ~/.codex, not this repo.
# See memory/google-auth.md and setup/google-persona-auth.md.
# RB_GCLOUD_CONFIG_DIR=~/.codex
# CODEX_GOOGLE_OAUTH_CLIENT_RICHMOND_BLACKWOOD_FILE=~/.codex/google-oauth-client.richmondblackwood.json

# Optional local-only ElevenLabs API fallback for agent/tool edits that MCP cannot expose.
# Never commit real values.
ELEVENLABS_API_KEY=
RB_ELEVENLABS_AGENT_ID=agent_2001kq39ea0hf5yb86c4a7hj9gp1

# Optional local-only ElevenLabs SIP trunk import/update helper.
# These are for local setup only. Never commit real values.
RB_ELEVENLABS_SIP_PHONE_NUMBER=
RB_ELEVENLABS_SIP_PHONE_LABEL=RB Calls Twilio SIP
RB_ELEVENLABS_SIP_PHONE_NUMBER_ID=
RB_TWILIO_SIP_TERMINATION_DOMAIN=
RB_TWILIO_SIP_USERNAME=
RB_TWILIO_SIP_PASSWORD=
RB_ELEVENLABS_SIP_TRANSPORT=tcp
RB_ELEVENLABS_SIP_MEDIA_ENCRYPTION=disabled
RB_ELEVENLABS_STORE_SIP_MESSAGES=true

# Optional local-only RB open banking setup.
# Keep real app IDs, private keys, tokens, sessions, account IDs, balances, transactions,
# statement exports, and raw bank data local only. See setup/mcp/rb-open-banking.md.
RB_BANK_ENABLE_BANKING_APP_ID=
RB_BANK_ENABLE_BANKING_PRIVATE_KEY_FILE=.codex-local/rb-open-banking/enable-banking-private.pem
RB_BANK_ENABLE_BANKING_REDIRECT_URL=https://example.com/rb-open-banking/callback
RB_BANK_ENABLE_BANKING_STORE_FILE=.codex-local/rb-open-banking/enable-banking-sessions.json
RB_BANK_ENABLE_BANKING_PSU_IP_ADDRESS=
RB_BANK_ENABLE_BANKING_PSU_USER_AGENT=
RB_BANK_WISE_API_BASE_URL=https://api.wise.com
RB_BANK_WISE_TOKEN_FILE=.codex-local/rb-open-banking/wise-token.txt

# Per-entity bank routing examples. Replace AKS with the env-safe Notion Company Reference.
RB_BANK_ENTITY_AKS_BOI_ASPSP_NAME=
RB_BANK_ENTITY_AKS_BOI_COUNTRY=IE
RB_BANK_ENTITY_AKS_BOI_SESSION_LABEL=aks-boi-business-operating
RB_BANK_ENTITY_AKS_BOI_SAFE_ALIAS=aks-boi-business-operating
RB_BANK_ENTITY_AKS_WAMO_ROUTE=enable_banking
RB_BANK_ENTITY_AKS_WAMO_ASPSP_NAME=
RB_BANK_ENTITY_AKS_WAMO_COUNTRY=IE
RB_BANK_ENTITY_AKS_WAMO_SESSION_LABEL=aks-wamo-operating
RB_BANK_ENTITY_AKS_WAMO_SAFE_ALIAS=aks-wamo-operating
RB_BANK_ENTITY_AKS_WISE_PROFILE_ID=
RB_BANK_ENTITY_AKS_WISE_TOKEN_FILE=
RB_BANK_ENTITY_AKS_WISE_SAFE_ALIAS=aks-wise-business-eur
