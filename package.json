{
  "name": "richmond-blackwood-codex",
  "version": "0.1.0",
  "private": true,
  "description": "Durable memory and local workflow helpers for Richmond Blackwood Codex.",
  "type": "commonjs",
  "engines": {
    "node": "18.7.0"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "calls:check-automation": "node --check automation/n8n/deploy-workflow-mcp.mjs && node --check automation/sync-rb-calls-live-state.mjs && node --check automation/n8n/rb-calls/voice-execution.workflow.mjs && node --check automation/n8n/rb-calls/live-help.workflow.mjs && node --check automation/n8n/rb-calls/elevenlabs-events.workflow.mjs && node --check automation/n8n/rb-calls/context-lookup.workflow.mjs && node --check automation/elevenlabs/rb-calls/patch-agent-live-help.mjs && node --check automation/elevenlabs/rb-calls/patch-agent-representation-opening.mjs && node --check automation/elevenlabs/rb-calls/patch-agent-slow-identifiers.mjs && node --check automation/elevenlabs/rb-calls/patch-agent-context-lookup.mjs && node --check automation/elevenlabs/rb-calls/patch-agent-startup-stability.mjs && node --check automation/elevenlabs/rb-calls/patch-agent-known-good-startup.mjs && node --check automation/elevenlabs/rb-calls/patch-agent-workflow-tools.mjs && node --check automation/elevenlabs/rb-calls/inspect-conversation.mjs && node --check automation/elevenlabs/rb-calls/inspect-conversation-detail.mjs && node --check automation/elevenlabs/rb-calls/inspect-agent.mjs && node --check automation/elevenlabs/rb-calls/inspect-agent-text.mjs",
    "calls:sync-live-state": "node automation/sync-rb-calls-live-state.mjs",
    "calls:deploy-n8n-workflow": "node automation/n8n/deploy-workflow-mcp.mjs",
    "calls:patch-elevenlabs-live-help": "node automation/elevenlabs/rb-calls/patch-agent-live-help.mjs",
    "calls:patch-elevenlabs-context-lookup": "node automation/elevenlabs/rb-calls/patch-agent-context-lookup.mjs",
    "calls:patch-elevenlabs-representation-opening": "node automation/elevenlabs/rb-calls/patch-agent-representation-opening.mjs",
    "calls:patch-elevenlabs-slow-identifiers": "node automation/elevenlabs/rb-calls/patch-agent-slow-identifiers.mjs",
    "calls:patch-elevenlabs-startup-stability": "node automation/elevenlabs/rb-calls/patch-agent-startup-stability.mjs",
    "calls:patch-elevenlabs-known-good-startup": "node automation/elevenlabs/rb-calls/patch-agent-known-good-startup.mjs",
    "calls:patch-elevenlabs-workflow-tools": "node automation/elevenlabs/rb-calls/patch-agent-workflow-tools.mjs",
    "calls:inspect-elevenlabs-conversation": "node automation/elevenlabs/rb-calls/inspect-conversation.mjs",
    "calls:inspect-elevenlabs-conversation-detail": "node automation/elevenlabs/rb-calls/inspect-conversation-detail.mjs",
    "calls:inspect-elevenlabs-agent": "node automation/elevenlabs/rb-calls/inspect-agent.mjs",
    "calls:inspect-elevenlabs-text": "node automation/elevenlabs/rb-calls/inspect-agent-text.mjs",
    "drive:upload": "node --require ts-node/register skills/rb-file-uploads/scripts/upload_to_drive.ts",
    "drive:export-google-doc-to-drive": "node --require ts-node/register skills/rb-file-uploads/scripts/export_google_doc_to_drive.ts",
    "drive:transform-google-doc": "node --require ts-node/register skills/rb-signature-workflow/scripts/transform_google_doc.ts",
    "gmail:create-alias-draft": "node --require ts-node/register skills/rb-gmail-drafts/scripts/create_alias_draft.ts",
    "gmail:delete-draft": "node --require ts-node/register skills/rb-gmail-drafts/scripts/delete_draft.ts",
    "pdf:prepare-signing-plan": "node --require ts-node/register skills/rb-signature-workflow/scripts/prepare_pdf_signing_plan.ts",
    "signnow:upload": "node --require ts-node/register skills/rb-signature-workflow/scripts/signnow_upload_document.ts",
    "signnow:get-document": "node --require ts-node/register skills/rb-signature-workflow/scripts/signnow_get_document.ts",
    "signnow:update-fields": "node --require ts-node/register skills/rb-signature-workflow/scripts/signnow_update_document_fields.ts",
    "signnow:embedded-review-link": "node --require ts-node/register skills/rb-signature-workflow/scripts/signnow_create_embedded_review_link.ts",
    "signnow:signature-status": "node --require ts-node/register skills/rb-signature-status-sync/scripts/signnow_signature_status.ts"
  },
  "dependencies": {
    "@signnow/api-client": "^3.2.0",
    "dotenv": "^16.4.7",
    "googleapis": "^171.4.0",
    "mime-types": "^2.1.35",
    "node-fetch": "^2.7.0",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@types/mime-types": "^3.0.1",
    "@types/node": "^18.19.127",
    "@types/node-fetch": "^2.6.13",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
